# ── Rankify Production Environment ──────────────────────────────────────────
# Configurações de produção - NUNCA COMMITAR VALORES REAIS!

# ── SMTP (Email Production) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=zkdopix@gmail.com
SMTP_PASS=zbfnuvbigijwbmch
SMTP_FROM="Rankify <noreply@rankify.com.br>"

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret
GOOGLE_REDIRECT_URI=https://seu-dominio.com/api/auth/google/callback

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seu-dominio.com

# ── Password Security ────────────────────────────────────────────────────────
# GERAR UMA CHAVE ALEATÓRIA SEGURA PARA PRODUÇÃO!
# Comando para gerar: openssl rand -base64 32
PASSWORD_PEPPER=sua-chave-pepper-aleatoria-segura-aqui

# ── Database ─────────────────────────────────────────────────────────────────
# Para produção, considere usar PostgreSQL ou MySQL
# DATABASE_URL=postgresql://user:password@localhost:5432/rankify

# ── Session Security ─────────────────────────────────────────────────────────
SESSION_SECRET=sua-chave-secreta-de-sessao-aleatoria
NODE_ENV=production