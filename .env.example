# URL da API
NEXT_PUBLIC_API_URL=https://rinkifyfy-kbve.vercel.app
NEXT_PUBLIC_APP_URL=https://rinkifyfy-kbve.vercel.app

# Configurações do banco de dados (SQLite)
DATABASE_URL=file:./rankify.db

# Segurança
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://rinkifyfy-kbve.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://rinkifyfy-kbve.vercel.app/api/auth/google/callback

# SMTP - Configurações do Gmail para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Rankify <noreply@rankify.com.br>"

# Password Security
PASSWORD_PEPPER=your-pepper-key-here
